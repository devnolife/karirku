# ============================================================
# Karir.ai — Environment Variables (EXAMPLE)
# Copy ke .env.local dan isi nilai yang sesungguhnya.
# Jangan commit .env.local ke git.
# ============================================================

# --- Database ---
DATABASE_URL="postgresql://karirku:karirku@localhost:5432/karirku?schema=public"

# --- Redis (BullMQ + cache) ---
REDIS_URL="redis://localhost:6379"

# --- Object Storage (MinIO, S3-compatible) ---
S3_ENDPOINT="http://localhost:9000"
S3_REGION="us-east-1"
S3_ACCESS_KEY="karirku"
S3_SECRET_KEY="karirku-dev-secret"
S3_BUCKET="karirku"

# --- Next.js / Auth.js ---
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth — https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- AI (Ollama lokal untuk dev; ganti ke vLLM endpoint di prod) ---
# OpenAI-compatible API base
OLLAMA_BASE_URL="http://localhost:11434/v1"
# API key wajib diisi tapi value tidak dipakai Ollama
OLLAMA_API_KEY="ollama"

# Model yang dipakai (pastikan sudah `ollama pull`)
# LLM = tugas berkualitas tinggi (kuis verifikasi skill, generasi konten).
# FAST = tugas ringan/volume tinggi (ekstraksi skill). EMBED = embedding 768d.
AI_MODEL_LLM="gemma3:27b"
AI_MODEL_FAST="qwen2.5:7b-instruct"
AI_MODEL_EMBED="nomic-embed-text"

# --- App ---
NODE_ENV="development"
LOG_LEVEL="info"
